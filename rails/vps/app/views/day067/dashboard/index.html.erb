<h1>Dashboard</h1>

<div class="stats">
  <div class="stat-card">
    <h3>Total Posts</h3>
    <p class="stat-number"><%= @post_count %></p>
  </div>

  <div class="stat-card">
    <h3>Latest Post</h3>
    <% if @latest_post %>
      <p><%= link_to @latest_post.title, post_path(@latest_post) %></p>
      <small><%= @latest_post.created_at.strftime("%Y-%m-%d") %></small>
    <% else %>
      <p>No posts yet</p>
    <% end %>
  </div>
</div>

<hr>

<h2>Quick Links</h2>
<ul>
  <li><%= link_to "All Posts", posts_path %></li>
  <li><%= link_to "Create New Post", new_post_path %></li>
</ul>
