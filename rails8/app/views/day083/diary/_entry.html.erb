<article class="rounded-[1.5rem] border border-stone-800 bg-stone-950/70 p-5">
  <div class="flex flex-wrap items-start justify-between gap-3">
    <div>
      <div class="flex flex-wrap items-center gap-2">
        <h3 class="text-lg font-semibold text-stone-50"><%= entry.title.presence || "Untitled Entry" %></h3>
        <span class="rounded-full bg-cyan-400/10 px-2.5 py-1 text-xs font-medium text-cyan-200">
          <%= entry.mood.titleize %>
        </span>
      </div>
      <p class="mt-2 text-xs uppercase tracking-[0.25em] text-stone-500">
        <%= entry.entry_on.strftime("%Y-%m-%d") %>
      </p>
    </div>

    <%= button_to "削除", day083_entry_path(entry), method: :delete, class: "rounded-full border border-stone-700 px-3 py-2 text-xs font-medium text-stone-300 transition hover:border-rose-400 hover:text-rose-300", form: { data: { turbo_confirm: "この日記を削除しますか？" } } %>
  </div>

  <p class="mt-4 whitespace-pre-wrap text-sm leading-7 text-stone-300"><%= entry.body %></p>
</article>
