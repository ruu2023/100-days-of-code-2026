<% if notice %>
  <div class="max-w-4xl mx-auto p-6">
    <p class="notice bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4"><%= notice %></p>
  </div>
<% end %>

<div class="max-w-4xl mx-auto p-6">
  <article class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <h1 class="text-3xl font-bold text-gray-800 mb-4"><%= @post.title %></h1>

    <p class="text-gray-700 whitespace-pre-wrap mb-6"><%= @post.body %></p>

    <small class="text-gray-500">Posted on <%= @post.created_at.strftime("%Y-%m-%d %H:%M") if @post.created_at %></small>
  </article>

  <div class="mt-6">
    <%= link_to "← Back", day067_posts_path, class: "text-blue-600 hover:text-blue-800 transition" %>
  </div>
</div>
