<div class="max-w-4xl mx-auto p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-800">Blog Posts</h1>
    <%= link_to "New Post", new_day067_post_path, class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg transition" %>
  </div>

  <% if @posts.any? %>
    <div class="space-y-4">
      <% @posts.each do |post| %>
        <article class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 hover:shadow-md transition">
          <h2 class="text-xl font-semibold text-gray-800 mb-2">
            <%= link_to post.title, day067_post_path(post), class: "hover:text-blue-600 transition" %>
          </h2>
          <p class="text-gray-600 mb-3"><%= post.body.truncate(200) if post.body %></p>
          <div class="flex justify-between items-center">
            <small class="text-gray-500"><%= post.created_at.strftime("%Y-%m-%d") if post.created_at %></small>
            <%= button_to "Delete", day067_post_path(post), method: :delete, class: "text-red-600 hover:text-red-800 text-sm" %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <p class="text-gray-500 text-center py-8">No posts yet.</p>
  <% end %>
</div>
