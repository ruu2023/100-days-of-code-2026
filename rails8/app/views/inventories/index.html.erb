<div class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex justify-between items-center mb-8">
    <h1 class="font-bold text-3xl text-gray-900">在庫管理</h1>
    <div class="text-sm text-gray-500">
      合計: <span id="inventory_count"><%= @inventories.count %></span>件
    </div>
  </div>
  <div class="mb-6 bg-white p-4 rounded-lg shadow-sm border border-gray-200">
    <%= form_with url: search_inventories_path, method: :get, data: { turbo_frame: "inventories_list" } do |f| %>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div>
          <%= f.label :q, "商品名", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.search_field :q, placeholder: "商品名で検索", class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm", value: params[:q] %>
        </div>
        <div>
          <%= f.label :code, "商品コード", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.search_field :code, placeholder: "コードで検索", class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm", value: params[:code] %>
        </div>
        <div>
          <%= f.label :location, "保管場所", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.select :location, options_for_select(Inventory.distinct.pluck(:location).compact, params[:location]), { include_blank: "全て" }, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
        </div>
        <div class="flex items-end gap-2">
          <%= f.submit "検索", class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
          <%= link_to "クリア", inventories_path, class: "inline-flex justify-center py-2 px-4 border border-gray-300 shadow-sm text-sm font-medium rounded-md bg-white hover:bg-gray-50" %>
        </div>
      </div>
    <% end %>
  </div>
  <div class="mb-6">
    <%= turbo_frame_tag "inventory_edit_form" do %>
    <% end %>
  </div>
  <div class="mb-6">
    <button type="button" id="toggle_new_form" class="w-full flex items-center justify-between bg-white rounded-lg shadow px-6 py-4 hover:bg-gray-50 transition-colors">
      <span class="text-lg font-medium text-gray-900">新規登録</span>
      <svg id="toggle_icon" class="w-5 h-5 text-gray-500 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
      </svg>
    </button>
    <div id="new_form_container" class="bg-white rounded-lg shadow p-6 mt-2 hidden">
      <%= turbo_frame_tag "inventory_form" do %>
        <%= render "form", inventory: @inventory %>
      <% end %>
    </div>
  </div>
  <div class="grid grid-cols-1 lg:grid-cols-1 gap-6">
    <%= turbo_frame_tag "inventories_list" do %>
      <div class="bg-white rounded-lg shadow overflow-hidden">
        <table class="divide-y divide-gray-200" style="width: 100%;">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">コード</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">商品名</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">数量</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">単位</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">保管場所</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">操作</th>
            </tr>
          </thead>
          <tbody id="inventories" class="bg-white divide-y divide-gray-200">
            <%= render @inventories %>
          </tbody>
        </table>
        <% if @inventories.empty? %>
          <div class="text-center py-12 text-gray-500">
            <p class="text-lg">在庫データがありません</p>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const toggleButton = document.getElementById('toggle_new_form');
    const formContainer = document.getElementById('new_form_container');
    const toggleIcon = document.getElementById('toggle_icon');

    if (toggleButton) {
      toggleButton.addEventListener('click', function() {
        formContainer.classList.toggle('hidden');
        toggleIcon.classList.toggle('rotate-180');
      });
    }
  });
</script>
