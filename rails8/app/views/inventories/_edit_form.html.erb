<%= turbo_frame_tag "inventory_edit_form" do %>
  <div class="bg-white rounded-lg shadow p-6 border-2 border-indigo-200 mb-6">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-lg font-medium text-gray-900">編集: <%= inventory.code %></h2>
      <%= link_to "キャンセル", inventories_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
    </div>
    <%= form_with model: inventory do |f| %>
      <% if inventory.errors.any? %>
        <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-md">
          <ul class="text-sm text-red-600">
            <% inventory.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
      <div class="space-y-4">
        <div>
          <%= f.label :code, class: "block text-sm font-medium text-gray-700" %>
          <%= f.text_field :code, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
        </div>
        <div>
          <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
          <%= f.text_field :name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <%= f.label :quantity, class: "block text-sm font-medium text-gray-700" %>
            <%= f.number_field :quantity, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
          </div>
          <div>
            <%= f.label :unit, class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :unit, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
          </div>
        </div>
        <div>
          <%= f.label :location, class: "block text-sm font-medium text-gray-700" %>
          <%= f.text_field :location, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
        </div>
        <div>
          <%= f.label :notes, class: "block text-sm font-medium text-gray-700" %>
          <%= f.text_area :notes, rows: 3, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" %>
        </div>
        <div>
          <%= f.submit "更新", class: "w-full inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md bg-indigo-600 hover:bg-indigo-700" %>
        </div>
      </div>
    <% end %>
  </div>
  <script>
    document.getElementById('new_form_container').style.display = 'none';
  </script>
<% end %>
