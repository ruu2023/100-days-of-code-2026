<% content_for :title, "ERD | 3D ER Diagram" %>
<% content_for :full_bleed, true %>

<div class="erd-studio">
  <aside class="erd-sidebar">
    <section class="erd-panel">
      <div class="erd-panel__header">
        <div>
          <p class="erd-kicker">MVP</p>
          <h1>Rails + Three.js ER 図</h1>
        </div>
        <%= link_to "新規図", new_erd_erd_diagram_path, class: "erd-button" %>
      </div>
      <p class="erd-panel__body">
        テーブル・カラム・リレーションを Rails で管理し、右側で 3D グラフとして確認します。
      </p>
    </section>

    <section class="erd-panel">
      <div class="erd-section__title">ER 図一覧</div>
      <div class="erd-stack">
        <% @diagrams.each do |diagram| %>
          <div class="erd-card <%= "is-active" if @diagram == diagram %>">
            <div>
              <strong><%= link_to diagram.name, erd_path(diagram_id: diagram.id) %></strong>
              <p><%= diagram.description.presence || "説明なし" %></p>
            </div>
            <div class="erd-card__actions">
              <%= link_to "編集", edit_erd_erd_diagram_path(diagram), class: "erd-link" %>
              <%= button_to "削除", erd_erd_diagram_path(diagram), method: :delete, class: "erd-link erd-link--danger", form: { data: { turbo_confirm: "ER 図を削除しますか？" } } %>
            </div>
          </div>
        <% end %>
      </div>

      <div class="erd-section__title">ER 図を追加</div>
      <%= render "diagram_form", diagram: @new_diagram, url: erd_erd_diagrams_path, submit_label: "図を作成" %>
    </section>

    <section class="erd-panel">
      <div class="erd-section__title">schema.rb 取り込み</div>
      <p class="erd-panel__body">
        Rails の <code>db/schema.rb</code> を読み込み、新しい ER 図を生成します。
      </p>
      <%= render "erd/schema_imports/form" %>
    </section>

    <% if @diagram.present? %>
      <section class="erd-panel">
        <div class="erd-section__title">テーブル追加</div>
        <%= render "erd/erd_tables/form", table: @erd_table, url: erd_erd_tables_path, submit_label: "テーブルを追加" %>
      </section>

      <section class="erd-panel">
        <div class="erd-section__title">カラム追加</div>
        <%= render "erd/erd_columns/form", column: @erd_column, url: erd_erd_columns_path, submit_label: "カラムを追加", tables: @diagram.erd_tables.order(:name) %>
      </section>

      <section class="erd-panel">
        <div class="erd-section__title">リレーション追加</div>
        <%= render "erd/erd_relationships/form", relationship: @erd_relationship.tap { |item| item.erd_diagram_id = @diagram.id }, url: erd_erd_relationships_path, submit_label: "リレーションを追加", tables: @diagram.erd_tables.order(:name) %>
      </section>

      <section class="erd-panel">
        <div class="erd-section__title">テーブル定義</div>
        <div class="erd-stack">
          <% @diagram.erd_tables.includes(:erd_columns).order(:name).each do |table| %>
            <article class="erd-card">
              <div class="erd-card__header">
                <div>
                  <strong><%= table.name %></strong>
                  <p><%= table.description.presence || "説明なし" %></p>
                </div>
                <div class="erd-card__actions">
                  <%= link_to "編集", edit_erd_erd_table_path(table), class: "erd-link" %>
                  <%= button_to "削除", erd_erd_table_path(table), method: :delete, class: "erd-link erd-link--danger", form: { data: { turbo_confirm: "テーブルを削除しますか？" } } %>
                </div>
              </div>
              <ul class="erd-list">
                <% table.erd_columns.order(primary_key: :desc, name: :asc).each do |column| %>
                  <li>
                    <span><%= column.primary_key? ? "PK " : "" %><%= column.name %> : <%= column.data_type %></span>
                    <span class="erd-list__meta"><%= column.null_allowed? ? "NULL" : "NOT NULL" %></span>
                    <span class="erd-list__actions">
                      <%= link_to "編集", edit_erd_erd_column_path(column), class: "erd-link" %>
                      <%= button_to "削除", erd_erd_column_path(column), method: :delete, class: "erd-link erd-link--danger", form: { data: { turbo_confirm: "カラムを削除しますか？" } } %>
                    </span>
                  </li>
                <% end %>
              </ul>
            </article>
          <% end %>
        </div>
      </section>

      <section class="erd-panel">
        <div class="erd-section__title">リレーション一覧</div>
        <ul class="erd-list">
          <% @diagram.erd_relationships.includes(:source_table, :target_table).order(:created_at).each do |relationship| %>
            <li>
              <span><%= relationship.label %> (<%= relationship.cardinality.humanize %>)</span>
              <span class="erd-list__actions">
                <%= link_to "編集", edit_erd_erd_relationship_path(relationship), class: "erd-link" %>
                <%= button_to "削除", erd_erd_relationship_path(relationship), method: :delete, class: "erd-link erd-link--danger", form: { data: { turbo_confirm: "リレーションを削除しますか？" } } %>
              </span>
            </li>
          <% end %>
        </ul>
      </section>
    <% end %>
  </aside>

  <section class="erd-canvas-panel">
    <% if @diagram.present? %>
      <div class="erd-canvas-panel__header">
        <div>
          <p class="erd-kicker">3D Graph</p>
          <h2><%= @diagram.name %></h2>
          <p><%= @diagram.description.presence || "右ドラッグで回転、ホイールでズーム、ノードドラッグで位置調整。" %></p>
        </div>
        <div class="erd-api-note">
          GET <code>/api/erd/erd_diagrams/<%= @diagram.id %>/graph</code><br>
          PATCH <code>/api/erd/erd_tables/:id/position</code>
        </div>
      </div>

      <section class="erd-panel erd-panel--legend">
        <div class="erd-section__title">凡例</div>
        <ul class="erd-legend">
          <li><strong>PK</strong> 主キー。テーブルを一意に識別します。</li>
          <li><strong>FK</strong> 外部キー。別テーブルの PK を参照します。</li>
          <li><strong>線</strong> テーブル間の参照関係です。</li>
          <li><strong>矢印</strong> FK を持つテーブルから、参照先テーブルへ向きます。</li>
          <li><strong>N:1</strong> FK 側が多、参照先 PK 側が 1 です。`comments -> users` のような関係を示します。</li>
          <li><strong>線ラベル</strong> `comments.user_id -> users.id` のように列の対応を示します。</li>
        </ul>
      </section>

      <div
        class="erd-graph-stage"
        data-controller="erd-graph"
        data-erd-graph-graph-url-value="<%= graph_api_erd_erd_diagram_path(@diagram) %>"
        data-erd-graph-position-base-value="/api/erd/erd_tables">
        <div class="erd-hover-modal" data-erd-graph-target="detail">
          ノードや線にホバーすると詳細が表示されます。
        </div>
        <div class="erd-canvas"></div>
      </div>
    <% else %>
      <div class="erd-empty">
        <h2>ER 図がまだありません</h2>
        <p>左のフォームから最初の図を作成してください。</p>
      </div>
    <% end %>
  </section>
</div>
