<div class="mx-auto max-w-6xl px-4 py-6 sm:px-6 lg:px-8">
  <div class="mb-6 grid gap-6 lg:grid-cols-[1.2fr_0.8fr]">
    <section class="rounded-3xl bg-slate-50 p-6 shadow-sm ring-1 ring-slate-200">
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">CSV Import</p>
      <h1 class="mt-1 text-3xl font-bold text-slate-900">CSV取り込み検索</h1>
      <p class="mt-2 text-sm text-slate-600">
        CSVをアップロードして推定結果を確認し、専用テーブルを作成してから検索できます。
        既存テーブルは変更せず、CSVごとに新しいテーブルを作ります。
      </p>
    </section>

    <section class="rounded-3xl bg-amber-50 p-6 shadow-sm ring-1 ring-amber-200">
      <h2 class="text-lg font-semibold text-amber-900">V1の安全策</h2>
      <ul class="mt-3 space-y-2 text-sm text-amber-900">
        <li>新規テーブル作成のみ</li>
        <li>既存テーブルの変更はしない</li>
        <li>推定後に明示実行しない限りDDLしない</li>
        <li>検索は全カラム横断の部分一致</li>
      </ul>
    </section>
  </div>

  <div class="grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
    <section class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
      <h2 class="text-xl font-semibold text-slate-900">新しいCSVを解析</h2>

      <% if @csv_import.errors.any? %>
        <div class="mt-4 rounded-2xl border border-red-200 bg-red-50 p-4 text-sm text-red-700">
          <% @csv_import.errors.full_messages.each do |message| %>
            <p><%= message %></p>
          <% end %>
        </div>
      <% end %>

      <%= form_with model: @csv_import, class: "mt-5 space-y-4" do |f| %>
        <div>
          <%= f.label :name, "表示名", class: "mb-2 block text-sm font-medium text-slate-700" %>
          <%= f.text_field :name, class: "w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm shadow-sm outline-none transition focus:border-slate-500 focus:ring-2 focus:ring-slate-200", placeholder: "例: 顧客マスタ 2026-04" %>
        </div>

        <div>
          <%= f.label :source_file, "CSVファイル", class: "mb-2 block text-sm font-medium text-slate-700" %>
          <%= f.file_field :source_file, accept: ".csv,text/csv", class: "block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm shadow-sm" %>
        </div>

        <%= f.submit "解析する", class: "inline-flex items-center justify-center rounded-2xl bg-slate-900 px-5 py-3 text-sm font-medium text-white shadow-sm transition hover:bg-slate-700" %>
      <% end %>
    </section>

    <section class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
      <div class="flex items-center justify-between gap-4">
        <h2 class="text-xl font-semibold text-slate-900">最近のインポート</h2>
        <span class="text-sm text-slate-500"><%= @csv_imports.size %>件</span>
      </div>

      <div class="mt-5 space-y-3">
        <% @csv_imports.each do |csv_import| %>
          <%= link_to csv_import_path(csv_import), class: "block rounded-2xl border border-slate-200 p-4 transition hover:border-slate-400 hover:bg-slate-50" do %>
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="font-medium text-slate-900"><%= csv_import.name %></p>
                <p class="mt-1 text-sm text-slate-500"><%= csv_import.source_filename %></p>
                <p class="mt-2 text-xs text-slate-500">推定 <%= csv_import.row_count %> 行 / <%= csv_import.target_table_name %></p>
              </div>
              <span class="rounded-full px-3 py-1 text-xs font-medium <%= csv_import.ready? ? "bg-emerald-100 text-emerald-800" : csv_import.failed? ? "bg-red-100 text-red-800" : "bg-slate-100 text-slate-700" %>">
                <%= csv_import.status %>
              </span>
            </div>
          <% end %>
        <% end %>

        <% if @csv_imports.empty? %>
          <p class="rounded-2xl border border-dashed border-slate-300 p-6 text-sm text-slate-500">まだCSVの解析履歴はありません。</p>
        <% end %>
      </div>
    </section>
  </div>
</div>
