<% content_for :title, "History" %>
<% content_for :full_bleed, true %>
<% content_for :head do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@400;500;700;900&display=swap" rel="stylesheet">
<% end %>

<div class="history-page" data-controller="timeline" data-timeline-events-value="<%= @events.to_json %>">
  <div class="history-page__backdrop" id="three-container"></div>

  <header class="history-page__hero">
    <p class="history-page__eyebrow">Rails 8 / History</p>
    <h1>歴史の流れを、白い紙面で読む。</h1>
    <p class="history-page__lede">
      余白を大きく、文字を太く、輪郭をはっきりさせたタイムラインです。
      スクロールに合わせて時代を追いながら、出来事をカードで確認できます。
    </p>
  </header>

  <div class="history-page__scroll" id="scroll-proxy" aria-hidden="true"></div>

  <div class="history-page__labels">
    <div id="timeline-labels" class="history-page__label-layer"></div>
  </div>
</div>

<style>
  body {
    margin: 0;
    overflow-x: hidden;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(244, 244, 240, 0.98)),
      repeating-linear-gradient(
        90deg,
        rgba(15, 23, 42, 0.04) 0,
        rgba(15, 23, 42, 0.04) 1px,
        transparent 1px,
        transparent 96px
      );
    color: #111111;
    font-family: "Zen Kaku Gothic New", "Hiragino Sans", "Yu Gothic", sans-serif;
  }

  .history-page {
    position: relative;
    min-height: 100vh;
  }

  .history-page__backdrop {
    position: fixed;
    inset: 0;
    z-index: 0;
  }

  .history-page__hero {
    position: fixed;
    top: 2rem;
    left: 2rem;
    z-index: 20;
    width: min(32rem, calc(100vw - 3rem));
    padding: 1.5rem 1.75rem;
    border: 2px solid rgba(17, 17, 17, 0.9);
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 12px 12px 0 rgba(17, 17, 17, 0.08);
  }

  .history-page__eyebrow {
    margin: 0 0 0.85rem;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .history-page__hero h1 {
    margin: 0;
    font-size: clamp(2.6rem, 4vw, 4.8rem);
    line-height: 0.95;
    font-weight: 900;
    letter-spacing: -0.04em;
  }

  .history-page__lede {
    margin: 1.15rem 0 0;
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    line-height: 1.75;
    max-width: 28rem;
  }

  .history-page__scroll {
    position: relative;
    z-index: 1;
    height: 500vh;
    width: 100%;
  }

  .history-page__labels {
    position: fixed;
    inset: 0;
    z-index: 10;
    pointer-events: none;
  }

  .history-page__label-layer {
    position: relative;
    width: 100vw;
    height: 100vh;
  }

  .history-card {
    position: absolute;
    width: min(26rem, calc(100vw - 3rem));
    padding: 1.2rem 1.25rem 1.15rem;
    border: 2px solid rgba(17, 17, 17, 0.92);
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 10px 10px 0 rgba(17, 17, 17, 0.08);
  }

  .history-card--left {
    top: 50%;
    right: 54%;
    transform: translateY(-50%);
  }

  .history-card--right {
    top: 50%;
    left: 54%;
    transform: translateY(-50%);
  }

  .history-card__year {
    margin: 0 0 0.5rem;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .history-card h3 {
    margin: 0;
    font-size: clamp(1.6rem, 2vw, 2.2rem);
    line-height: 1.1;
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .history-card p {
    margin: 0.8rem 0 0;
    font-size: 1rem;
    line-height: 1.8;
  }

  .history-card .history-card__year {
    margin-top: 0;
  }

  @media (max-width: 900px) {
    .history-page__hero {
      top: 1rem;
      left: 1rem;
      width: calc(100vw - 2rem);
      padding: 1.2rem;
    }

    .history-card--left,
    .history-card--right {
      top: auto;
      right: 1rem;
      left: 1rem;
      bottom: 1rem;
      transform: none;
    }
  }
</style>
