<div class="mx-auto max-w-6xl px-4 py-6 sm:px-6 lg:px-8">
  <div class="mb-6 flex flex-col gap-4 rounded-3xl bg-slate-50 p-6 shadow-sm ring-1 ring-slate-200 lg:flex-row lg:items-start lg:justify-between">
    <div>
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">Statement CSV Import</p>
      <h1 class="mt-1 text-3xl font-bold text-slate-900"><%= @statement_csv_import.name %></h1>
      <p class="mt-2 text-sm text-slate-600"><%= @statement_csv_import.statement_csv_import_files.count %>ファイル / <%= @datasets.count %>データセット</p>
      <p class="mt-2 text-xs text-slate-500">作成日時: <%= @statement_csv_import.created_at.strftime("%Y-%m-%d %H:%M") %></p>
    </div>

    <div class="flex flex-col items-start gap-3 lg:items-end">
      <span class="rounded-full px-3 py-1 text-xs font-medium <%= @statement_csv_import.ready? ? "bg-emerald-100 text-emerald-800" : @statement_csv_import.failed? ? "bg-red-100 text-red-800" : "bg-slate-200 text-slate-700" %>">
        <%= @statement_csv_import.status %>
      </span>

      <% unless @statement_csv_import.ready? %>
        <%= button_to "グループ単位で取り込む", run_import_statement_csv_import_path(@statement_csv_import), method: :post, class: "inline-flex items-center justify-center rounded-2xl bg-slate-900 px-5 py-3 text-sm font-medium text-white shadow-sm transition hover:bg-slate-700" %>
      <% end %>

      <%= link_to "一覧へ戻る", statement_csv_imports_path, class: "text-sm font-medium text-slate-600 hover:text-slate-900" %>
    </div>
  </div>

  <% if @statement_csv_import.error_message.present? %>
    <div class="mb-6 rounded-2xl border border-red-200 bg-red-50 p-4 text-sm text-red-700">
      <%= @statement_csv_import.error_message %>
    </div>
  <% end %>

  <section class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
    <div class="flex items-center justify-between gap-4">
      <div>
        <h2 class="text-xl font-semibold text-slate-900">解析済みデータセット</h2>
        <p class="mt-1 text-sm text-slate-600">同じヘッダーのファイルは同じデータセットにまとまります。</p>
      </div>
    </div>

    <div class="mt-5 space-y-4">
      <% @datasets.each do |dataset| %>
        <div class="rounded-3xl border border-slate-200 p-5">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
            <div>
              <div class="flex items-center gap-2">
                <h3 class="text-lg font-semibold text-slate-900"><%= dataset.name %></h3>
                <span class="rounded-full px-3 py-1 text-xs font-medium <%= dataset.ready? ? "bg-emerald-100 text-emerald-800" : dataset.failed? ? "bg-red-100 text-red-800" : "bg-slate-100 text-slate-700" %>">
                  <%= dataset.status %>
                </span>
              </div>
              <p class="mt-2 text-sm text-slate-600">
                保存先:
                <code><%= dataset.target_table_name %></code>
                (<%= dataset.append_target? ? "既存テーブルへ追記" : "新規テーブル" %>)
              </p>
              <p class="mt-2 text-xs text-slate-500"><%= dataset.row_count %>行 / <%= dataset.column_names_for_search.size %>カラム</p>
            </div>

            <%= link_to "データセット詳細", statement_csv_import_dataset_path(dataset), class: "inline-flex items-center justify-center rounded-2xl border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-slate-500 hover:text-slate-900" %>
          </div>

          <div class="mt-4 grid gap-4 lg:grid-cols-[0.8fr_1.2fr]">
            <div class="rounded-2xl bg-slate-50 p-4">
              <p class="text-sm font-semibold text-slate-900">含まれるファイル</p>
              <ul class="mt-3 space-y-2 text-sm text-slate-600">
                <% dataset.statement_csv_import_files.order(:id).each do |file_record| %>
                  <li><%= file_record.source_filename %> (<%= file_record.row_count %>行)</li>
                <% end %>
              </ul>
            </div>

            <div class="overflow-auto rounded-2xl border border-slate-200">
              <table class="min-w-full divide-y divide-slate-200 text-sm">
                <thead class="bg-slate-50">
                  <tr>
                    <% dataset.column_names_for_search.each do |column_name| %>
                      <th class="px-4 py-3 text-left font-medium text-slate-600"><%= column_name %></th>
                    <% end %>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 bg-white">
                  <% dataset.sample_rows_for_preview.first(5).each do |row| %>
                    <tr>
                      <% dataset.column_names_for_search.each do |column_name| %>
                        <td class="max-w-xs px-4 py-3 align-top text-slate-700"><%= row[column_name] %></td>
                      <% end %>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </section>
</div>
