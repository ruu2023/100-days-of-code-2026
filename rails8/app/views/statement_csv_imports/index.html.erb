<div class="mx-auto max-w-6xl px-4 py-6 sm:px-6 lg:px-8">
  <div class="mb-6 grid gap-6 lg:grid-cols-[1.2fr_0.8fr]">
    <section class="rounded-3xl bg-slate-50 p-6 shadow-sm ring-1 ring-slate-200">
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">Statement CSV Import</p>
      <h1 class="mt-1 text-3xl font-bold text-slate-900">明細CSVまとめ取り込み</h1>
      <p class="mt-2 text-sm text-slate-600">
        クレカ明細CSVを複数まとめて解析し、同じヘッダーのファイルは同じテーブルへ取り込みます。
        既存の <code>csv_imports</code> はそのまま残し、新しいルートで独立運用します。
      </p>
    </section>

    <section class="rounded-3xl bg-amber-50 p-6 shadow-sm ring-1 ring-amber-200">
      <h2 class="text-lg font-semibold text-amber-900">この画面の前提</h2>
      <ul class="mt-3 space-y-2 text-sm text-amber-900">
        <li>複数ファイルを一括選択できます</li>
        <li>同一ヘッダーのみ同じテーブルへ入れます</li>
        <li>ヘッダーが違うCSVは別テーブルです</li>
        <li>既存テーブルへの追記にも対応します</li>
      </ul>
    </section>
  </div>

  <div class="grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
    <section class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
      <h2 class="text-xl font-semibold text-slate-900">新しい明細CSVを解析</h2>

      <% if @statement_csv_import.errors.any? %>
        <div class="mt-4 rounded-2xl border border-red-200 bg-red-50 p-4 text-sm text-red-700">
          <% @statement_csv_import.errors.full_messages.each do |message| %>
            <p><%= message %></p>
          <% end %>
        </div>
      <% end %>

      <%= form_with model: @statement_csv_import, html: { multipart: true }, class: "mt-5 space-y-4" do |f| %>
        <div>
          <%= f.label :name, "表示名", class: "mb-2 block text-sm font-medium text-slate-700" %>
          <%= f.text_field :name, class: "w-full rounded-2xl border border-slate-300 px-4 py-3 text-sm shadow-sm outline-none transition focus:border-slate-500 focus:ring-2 focus:ring-slate-200", placeholder: "例: クレカ明細 2026 春" %>
        </div>

        <div>
          <label class="mb-2 block text-sm font-medium text-slate-700" for="statement_csv_import_source_files">CSVファイル</label>
          <%= file_field_tag "statement_csv_import[source_files][]", multiple: true, accept: ".csv,text/csv", class: "block w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm shadow-sm", id: "statement_csv_import_source_files" %>
          <p class="mt-2 text-xs text-slate-500">同じカード会社の月別CSVをまとめて選ぶと、同じヘッダーなら1テーブルに集約されます。</p>
        </div>

        <%= f.submit "解析する", class: "inline-flex items-center justify-center rounded-2xl bg-slate-900 px-5 py-3 text-sm font-medium text-white shadow-sm transition hover:bg-slate-700" %>
      <% end %>
    </section>

    <section class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
      <div class="flex items-center justify-between gap-4">
        <h2 class="text-xl font-semibold text-slate-900">最近の取込セッション</h2>
        <span class="text-sm text-slate-500"><%= @statement_csv_imports.size %>件</span>
      </div>

      <div class="mt-5 space-y-3">
        <% @statement_csv_imports.each do |statement_csv_import| %>
          <%= link_to statement_csv_import_path(statement_csv_import), class: "block rounded-2xl border border-slate-200 p-4 transition hover:border-slate-400 hover:bg-slate-50" do %>
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="font-medium text-slate-900"><%= statement_csv_import.name %></p>
                <p class="mt-1 text-sm text-slate-500"><%= statement_csv_import.statement_csv_import_files.count %>ファイル / <%= statement_csv_import.statement_csv_import_datasets.count %>データセット</p>
                <p class="mt-2 text-xs text-slate-500"><%= statement_csv_import.created_at.strftime("%Y-%m-%d %H:%M") %></p>
              </div>
              <span class="rounded-full px-3 py-1 text-xs font-medium <%= statement_csv_import.ready? ? "bg-emerald-100 text-emerald-800" : statement_csv_import.failed? ? "bg-red-100 text-red-800" : "bg-slate-100 text-slate-700" %>">
                <%= statement_csv_import.status %>
              </span>
            </div>
          <% end %>
        <% end %>

        <% if @statement_csv_imports.empty? %>
          <p class="rounded-2xl border border-dashed border-slate-300 p-6 text-sm text-slate-500">まだ複数明細の解析履歴はありません。</p>
        <% end %>
      </div>
    </section>
  </div>
</div>
