<article class="p-4 border-b border-gray-800 hover:bg-gray-900/50 transition-colors" id="<%= dom_id post %>">
  <div class="flex gap-3">
    <%= image_tag post.user.profile_image, alt: post.user.display_name, class: "w-10 h-10 rounded-full flex-shrink-0" %>

    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-1">
        <span class="font-bold"><%= post.user.display_name %></span>
        <span class="text-gray-500">@<%= post.user.email_address.split("@").first %></span>
        <span class="text-gray-500">·</span>
        <span class="text-gray-500 text-sm"><%= time_ago_in_words(post.created_at) %></span>
      </div>

      <p class="mt-1 whitespace-pre-wrap break-words"><%= post.body %></p>

      <% if post.media.attached? %>
        <div class="mt-3 grid gap-2 <%= post.media.count > 1 ? 'grid-cols-2' : 'grid-cols-1' %>">
          <% post.media.each do |attachment| %>
            <% if attachment.image? %>
              <%= image_tag attachment.variant(:medium), class: "rounded-xl w-full object-cover max-h-80" %>
            <% elsif attachment.video? %>
              <video controls class="rounded-xl w-full max-h-80" playsinline muted>
                <source src="<%= rails_blob_url(attachment) %>" type="<%= attachment.content_type %>">
              </video>
            <% end %>
          <% end %>
        </div>
      <% end %>

      <div class="flex justify-between mt-3 text-gray-500">
        <button class="hover:text-blue-400 flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
          </svg>
          <span><%= post.comments.count %></span>
        </button>

        <% if authenticated? && post.user == Current.user %>
          <%= button_to post_path(post), method: :delete, class: "hover:text-red-500", data: { confirm: "Delete this post?" } do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
            </svg>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</article>
