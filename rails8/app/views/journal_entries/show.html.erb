<% content_for :title, @journal_entry.entry_number %>
<% content_for :head do %>
  <meta name="turbo-frame-policy" content="none">
<% end %>

<div class="max-w-4xl mx-auto p-4 pb-24 md:pb-4">
  <div class="mb-6">
    <%= link_to accounting_journal_entries_path, class: "text-blue-600 hover:text-blue-800 flex items-center gap-1 mb-4" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
      </svg>
      Back to Journal Entries
    <% end %>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <!-- Header -->
    <div class="bg-gray-50 px-6 py-4 border-b border-gray-200 flex items-center justify-between">
      <div>
        <h1 class="text-xl font-bold text-gray-900"><%= @journal_entry.entry_number %></h1>
        <p class="text-sm text-gray-500 mt-1"><%= @journal_entry.entry_date.strftime("%B %d, %Y") %></p>
      </div>
      <div class="flex items-center gap-3">
        <% if @journal_entry.posted? %>
          <span class="inline-flex px-3 py-1 text-sm font-medium rounded-full bg-green-100 text-green-800">Posted</span>
        <% else %>
          <span class="inline-flex px-3 py-1 text-sm font-medium rounded-full bg-yellow-100 text-yellow-800">Draft</span>
          <%= button_to "Post Entry", post_accounting_journal_entry_path(@journal_entry),
              method: :post,
              class: "px-4 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700" %>
        <% end %>
      </div>
    </div>

    <!-- Details -->
    <div class="p-6">
      <div class="grid grid-cols-2 gap-6 mb-6">
        <div>
          <p class="text-sm text-gray-500">Description</p>
          <p class="mt-1 text-gray-900"><%= @journal_entry.description || "-" %></p>
        </div>
        <div>
          <p class="text-sm text-gray-500">Party</p>
          <p class="mt-1 text-gray-900"><%= @journal_entry.party&.name || "-" %></p>
        </div>
      </div>

      <!-- Line Items -->
      <h2 class="text-sm font-medium text-gray-700 mb-3">Line Items</h2>
      <table class="w-full">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Account</th>
            <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase">Type</th>
            <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase">Debit</th>
            <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase">Credit</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @journal_entry.line_items.each do |item| %>
            <tr>
              <td class="px-4 py-3 text-sm text-gray-900"><%= item.account.name %></td>
              <td class="px-4 py-3 text-sm text-gray-500"><%= item.account.account_type.titleize %></td>
              <td class="px-4 py-3 text-sm text-right <%= item.debit.positive? ? 'font-medium text-gray-900' : 'text-gray-400' %>">
                <%= item.debit.positive? ? number_to_currency(item.debit) : "-" %>
              </td>
              <td class="px-4 py-3 text-sm text-right <%= item.credit.positive? ? 'font-medium text-gray-900' : 'text-gray-400' %>">
                <%= item.credit.positive? ? number_to_currency(item.credit) : "-" %>
              </td>
            </tr>
          <% end %>
        </tbody>
        <tfoot class="bg-gray-50 font-medium">
          <tr>
            <td class="px-4 py-3 text-sm text-gray-900" colspan="2">Total</td>
            <td class="px-4 py-3 text-sm text-right text-gray-900"><%= number_to_currency(@journal_entry.total_debits) %></td>
            <td class="px-4 py-3 text-sm text-right text-gray-900"><%= number_to_currency(@journal_entry.total_credits) %></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>
</div>
