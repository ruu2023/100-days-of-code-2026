<% content_for :title, "新規取引" %>
<% content_for :head do %>
  <meta name="turbo-frame-policy" content="none">
<% end %>

<div class="max-w-2xl mx-auto p-4 pb-24 md:pb-4">
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="bg-gray-50 px-6 py-4 border-b border-gray-200">
      <h1 class="text-xl font-bold text-gray-900">新規取引</h1>
    </div>

    <%= form_with(model: @journal_entry, url: accounting_journal_entries_path, class: "p-6 space-y-5") do |f| %>
      <% if @journal_entry.errors.any? %>
        <div class="bg-red-50 border border-red-200 rounded-lg p-4">
          <ul class="list-disc list-inside text-sm text-red-600">
            <% @journal_entry.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <!-- Date -->
      <div>
        <%= f.label :entry_date, "日付", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.date_field :entry_date,
            value: Date.today,
            class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
            required: true %>
      </div>

      <!-- Party -->
      <div>
        <%= f.label :party_id, "支払先", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <div class="relative"
             data-controller="party-autocomplete"
             data-party-autocomplete-search-url-value="<%= search_accounting_parties_path %>"
             data-party-autocomplete-party-type-value="client">

          <%= text_field_tag :party_search, nil,
              class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
              placeholder: "検索...",
              autocomplete: "off" %>

          <%= f.hidden_field :party_id, data: { "party-autocomplete-target": "hiddenId" } %>
          <div data-party-autocomplete-target="results" class="hidden"></div>
          <%= turbo_frame_tag "quick_add_party", src: "", class: "hidden absolute top-full left-0 right-0 z-50 mt-1" %>
        </div>
      </div>

      <!-- Description -->
      <div>
        <%= f.label :description, "摘要", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :description,
            class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
            placeholder: "何の取引ですか？" %>
      </div>

      <!-- Transaction Form - using nested attributes -->
      <div>
        <h3 class="text-sm font-medium text-gray-700 mb-3">取引内容</h3>

        <!-- 借方 -->
        <div class="mb-2">
          <label class="block text-xs text-gray-500 mb-1">借方</label>
          <div class="flex gap-2">
            <div class="flex-1">
              <select name="journal_entry[line_items_attributes][0][account_id]" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
                <option value="">勘定科目</option>
                <% Account.active.order(:name).each do |account| %>
                  <option value="<%= account.id %>"><%= account.name %></option>
                <% end %>
              </select>
            </div>
            <div class="w-32">
              <input type="number" name="journal_entry[line_items_attributes][0][debit]" class="debit-input w-full px-3 py-2 border border-gray-300 rounded-lg text-sm text-right" placeholder="金額" step="1" min="0">
            </div>
            <input type="hidden" name="journal_entry[line_items_attributes][0][credit]" value="0">
          </div>
        </div>

        <!-- 贷方 -->
        <div>
          <label class="block text-xs text-gray-500 mb-1">贷方</label>
          <div class="flex gap-2">
            <div class="flex-1">
              <select name="journal_entry[line_items_attributes][1][account_id]" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
                <option value="">勘定科目</option>
                <% Account.active.order(:name).each do |account| %>
                  <option value="<%= account.id %>"><%= account.name %></option>
                <% end %>
              </select>
            </div>
            <div class="w-32">
              <input type="number" name="journal_entry[line_items_attributes][1][credit]" class="credit-input w-full px-3 py-2 border border-gray-300 rounded-lg text-sm text-right" placeholder="金額" step="1" min="0">
            </div>
            <input type="hidden" name="journal_entry[line_items_attributes][1][debit]" value="0">
          </div>
        </div>
      </div>

      <!-- Total -->
      <div class="bg-gray-100 rounded-lg p-4 text-center">
        <p class="text-sm text-gray-500">合計</p>
        <p class="text-3xl font-bold text-gray-900" id="total-display">¥0</p>
      </div>

      <!-- Actions -->
      <div class="flex gap-3 pt-2">
        <%= f.submit "保存",
            class: "flex-1 px-6 py-3 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200 focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 transition-colors" %>
        <%= f.submit "登録",
            class: "flex-1 px-6 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors" %>
      </div>
    <% end %>
  </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function() {
  const debitInput = document.querySelector('.debit-input');
  const creditInput = document.querySelector('.credit-input');
  const totalDisplay = document.getElementById('total-display');

  function syncAmount() {
    const val = parseFloat(debitInput.value) || 0;
    creditInput.value = val;
    totalDisplay.textContent = '¥' + val.toLocaleString();
  }

  debitInput.addEventListener('input', syncAmount);

  // Initial
  syncAmount();
});
</script>
