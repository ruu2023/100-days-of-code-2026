<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "X Clone" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="X Clone">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-black text-white">
    <div class="min-h-screen flex">

      <!-- Main content -->
      <main class="flex-1 max-w-xl border-r border-gray-800">
        <header class="sticky top-0 bg-black/80 backdrop-blur-md border-b border-gray-800 p-4 z-10">
          <h1 class="text-xl font-bold"><%= @query.present? ? "Search Results" : "Home" %></h1>
        </header>

        <div class="p-4 border-b border-gray-800">
          <% if authenticated? %>
            <div class="flex gap-3">
              <%= image_tag Current.user.profile_image, alt: "Profile", class: "w-10 h-10 rounded-full" %>
              <%= form_with(model: @post || Post.new, url: posts_path, class: "flex-1", data: { controller: "preview", action: "turbo:submit-end->preview#resetForm" }) do |f| %>
                <%= f.text_area :body, placeholder: "What is happening?!", class: "w-full bg-transparent text-xl outline-none resize-none placeholder-gray-500", rows: 2 %>

                <!-- Preview area -->
                <div data-preview-target="output" class="grid grid-cols-2 gap-2 mt-3"></div>

                <div class="flex justify-between items-center mt-3">
                  <label class="cursor-pointer text-blue-400 hover:text-blue-500">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    <%= f.file_field :media, multiple: true, class: "hidden", accept: "image/*,video/*", data: { action: "change->preview#display" } %>
                  </label>
                  <%= f.submit "Post", class: "bg-blue-500 hover:bg-blue-600 text-white font-bold py-2 px-4 rounded-full" %>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="text-center py-4">
              <h2 class="text-2xl font-bold mb-4">Welcome to X</h2>
              <%= button_to "/auth/google_oauth2", method: :post, data: { turbo: false }, class: "inline-block bg-blue-500 hover:bg-blue-600 text-white font-bold py-3 px-8 rounded-full cursor-pointer" do %>
                Sign in with Google
              <% end %>
            </div>
          <% end %>
        </div>

        <div id="posts">
          <%= yield %>
        </div>
      </main>

      <!-- Right sidebar -->
      <aside class="hidden lg:block w-80 p-4">
        <%= form_with url: search_path, method: :get, class: "mb-4" do |f| %>
          <div class="bg-gray-900 rounded-full p-3 flex items-center">
            <svg class="w-5 h-5 text-gray-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <%= f.search_field :q, placeholder: "Search", value: @query, class: "bg-transparent outline-none w-full", data: { turbo_action: "replace" } %>
          </div>
        <% end %>

        <div class="bg-gray-900 rounded-2xl p-4">
          <h2 class="text-xl font-bold mb-3">What's happening</h2>
          <p class="text-gray-500">Sign in to see trending topics</p>
        </div>
      </aside>
    </div>
  </body>
</html>
