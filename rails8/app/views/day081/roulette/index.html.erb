<% content_for :title, "Day081 Roulette" %>

<div
  class="min-h-screen bg-[radial-gradient(circle_at_top,_#fff7c2_0%,_#fff8eb_32%,_#f7fbff_72%,_#eef6ff_100%)] px-4 py-8 text-slate-900"
  data-controller="day081-roulette"
  data-day081-roulette-initial-state-value="<%= json_escape(@roulette_data.to_json) %>"
>
  <div class="mx-auto max-w-7xl">
    <div class="rounded-[2rem] border border-white/80 bg-white/90 p-6 shadow-[0_24px_80px_rgba(148,163,184,0.18)] backdrop-blur md:p-8">
      <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
        <div class="max-w-2xl">
          <p class="text-sm font-semibold uppercase tracking-[0.35em] text-amber-600">Day081</p>
          <h1 class="mt-3 text-4xl font-black tracking-tight text-slate-950 md:text-5xl">Roulette Playground</h1>
          <p class="mt-4 text-base leading-7 text-slate-600">
            名前でも罰ゲームでも、どんどん追加してその場で回せるルーレットです。選ばれた項目は自動でチェックされ、次回以降は抽選対象から外れます。
          </p>
        </div>

        <div class="grid gap-3 sm:grid-cols-2">
          <button
            type="button"
            class="rounded-full border border-slate-300 bg-white px-5 py-3 text-sm font-semibold uppercase tracking-[0.22em] text-slate-700 transition data-[active=true]:border-slate-900 data-[active=true]:bg-slate-900 data-[active=true]:text-white"
            data-mode-tab="names"
            data-action="click->day081-roulette#switchMode"
            data-day081-roulette-mode-param="names"
          >
            名前
          </button>
          <button
            type="button"
            class="rounded-full border border-slate-300 bg-white px-5 py-3 text-sm font-semibold uppercase tracking-[0.22em] text-slate-700 transition data-[active=true]:border-slate-900 data-[active=true]:bg-slate-900 data-[active=true]:text-white"
            data-mode-tab="punishments"
            data-action="click->day081-roulette#switchMode"
            data-day081-roulette-mode-param="punishments"
          >
            罰ゲーム
          </button>
          <button
            type="button"
            class="rounded-full border border-amber-300 bg-amber-100 px-5 py-3 text-sm font-semibold uppercase tracking-[0.22em] text-amber-900 transition hover:bg-amber-200"
            data-action="click->day081-roulette#resetMode"
          >
            今のカテゴリをリセット
          </button>
          <button
            type="button"
            class="rounded-full border border-rose-300 bg-rose-100 px-5 py-3 text-sm font-semibold uppercase tracking-[0.22em] text-rose-900 transition hover:bg-rose-200"
            data-action="click->day081-roulette#resetAll"
          >
            全部初期化
          </button>
        </div>
      </div>

      <div class="mt-8 grid gap-8 xl:grid-cols-[1.2fr_0.8fr]">
        <section class="rounded-[2rem] border border-amber-100 bg-[linear-gradient(160deg,_#fffef7_0%,_#fff8dc_38%,_#fff1f2_100%)] px-5 py-6 text-slate-900 shadow-[0_24px_80px_rgba(251,191,36,0.14)] md:px-8">
          <div class="grid gap-8 lg:justify-center lg:grid-cols-[minmax(0,600px)_300px] lg:items-center">
            <div class="relative mx-auto aspect-square w-full" style="max-width: min(100%, 600px);">
              <div class="absolute left-1/2 top-0 z-20 h-0 w-0 -translate-x-1/2 border-x-[18px] border-t-[28px] border-x-transparent border-t-amber-400 drop-shadow-[0_10px_18px_rgba(251,191,36,0.45)]"></div>
              <div
                class="absolute inset-0 rounded-full border-[16px] border-white shadow-[inset_0_0_0_12px_rgba(255,255,255,0.55),0_28px_70px_rgba(251,191,36,0.22)] transition-transform duration-[4800ms] ease-[cubic-bezier(0.17,0.84,0.44,1)]"
                data-day081-roulette-target="wheel"
              >
                <div data-day081-roulette-target="wheelLabels" class="absolute inset-0"></div>
                <div class="absolute inset-[22%] rounded-full border border-white/80 bg-[radial-gradient(circle_at_30%_30%,_#fffef5_0%,_#fff3c4_42%,_#fcd34d_100%)] shadow-[inset_0_16px_36px_rgba(255,255,255,0.45)]"></div>
              </div>
              <div class="absolute inset-0 hidden items-center justify-center rounded-full border border-dashed border-amber-200 bg-white/80 text-center text-sm uppercase tracking-[0.3em] text-amber-800" data-day081-roulette-target="empty">
                候補がありません
              </div>
            </div>

            <div class="space-y-4">
              <div class="rounded-[1.75rem] bg-white/75 p-5 ring-1 ring-amber-100">
                <p class="text-xs font-semibold uppercase tracking-[0.34em] text-amber-700">Current Result</p>
                <p class="mt-3 text-4xl font-black tracking-tight text-slate-950" data-day081-roulette-target="result">Ready</p>
                <p class="mt-3 text-sm leading-6 text-slate-600" data-day081-roulette-target="resultMeta">抽選すると、ここに結果が表示されます。</p>
              </div>

              <div class="rounded-[1.75rem] bg-white p-4 text-slate-900 shadow-sm" data-day081-roulette-target="summary"></div>

              <button
                type="button"
                class="w-full rounded-full bg-amber-400 px-6 py-4 text-sm font-black uppercase tracking-[0.3em] text-slate-950 shadow-[0_16px_32px_rgba(251,191,36,0.32)] transition hover:translate-y-[-1px] hover:bg-amber-300 disabled:cursor-not-allowed disabled:bg-slate-500 disabled:text-slate-200"
                data-action="click->day081-roulette#spin"
                data-day081-roulette-target="spinButton"
              >
                Spin
              </button>
            </div>
          </div>
        </section>

        <section class="grid gap-6">
          <div class="rounded-[2rem] border border-slate-200 bg-slate-50 p-5">
            <h2 class="text-lg font-black tracking-tight text-slate-950">候補を追加</h2>
            <p class="mt-2 text-sm leading-6 text-slate-600">単発追加とまとめ追加の両方に対応しています。名前でも罰ゲームでも、選んだカテゴリにそのまま積み増されます。</p>

            <div class="mt-5 grid gap-3 sm:grid-cols-[minmax(0,1fr)_auto]">
              <input
                type="text"
                placeholder="1件追加する"
                class="rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 outline-none ring-0 transition focus:border-slate-950"
                data-day081-roulette-target="singleInput"
              >
              <button
                type="button"
                class="rounded-2xl bg-slate-950 px-5 py-3 text-sm font-semibold uppercase tracking-[0.2em] text-white transition hover:bg-slate-800"
                data-action="click->day081-roulette#addSingleItem"
              >
                Add
              </button>
            </div>

            <div class="mt-4 grid gap-3">
              <textarea
                rows="6"
                placeholder="改行ごとにまとめて追加"
                class="rounded-[1.5rem] border border-slate-300 bg-white px-4 py-3 text-sm leading-6 text-slate-900 outline-none transition focus:border-slate-950"
                data-day081-roulette-target="bulkInput"
              ></textarea>
              <button
                type="button"
                class="rounded-2xl border border-slate-300 bg-white px-5 py-3 text-sm font-semibold uppercase tracking-[0.2em] text-slate-700 transition hover:border-slate-950 hover:text-slate-950"
                data-action="click->day081-roulette#addBulkItems"
              >
                Bulk Add
              </button>
            </div>
          </div>

          <div class="grid gap-6 lg:grid-cols-2">
            <div class="rounded-[2rem] border border-slate-200 bg-white p-5">
              <h2 class="text-lg font-black tracking-tight text-slate-950">抽選対象</h2>
              <div class="mt-4 grid gap-3" data-day081-roulette-target="activeList"></div>
            </div>

            <div class="rounded-[2rem] border border-slate-200 bg-white p-5">
              <h2 class="text-lg font-black tracking-tight text-slate-950">使用済み</h2>
              <div class="mt-4 grid gap-3" data-day081-roulette-target="usedList"></div>
            </div>
          </div>
        </section>
      </div>
    </div>
  </div>
</div>
