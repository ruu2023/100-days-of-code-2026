<%= form_with model: subscription, url: (subscription.new_record? ? day085_subscriptions_path : day085_subscription_path(subscription)), class: "bg-white rounded shadow p-6" do |f| %>
  <% if subscription.errors.any? %>
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
      <ul>
        <% subscription.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :name, class: "block text-gray-700 font-medium mb-1" %>
      <%= f.text_field :name, class: "w-full border rounded px-3 py-2", required: true %>
    </div>

    <div>
      <%= f.label :category_id, class: "block text-gray-700 font-medium mb-1" %>
      <%= f.select :category_id, options_from_collection_for_select(@categories, :id, :name, subscription.category_id), { include_blank: "Select Category" }, class: "w-full border rounded px-3 py-2" %>
    </div>

    <div>
      <%= f.label :price, class: "block text-gray-700 font-medium mb-1" %>
      <%= f.number_field :price, step: "0.01", min: "0", class: "w-full border rounded px-3 py-2", required: true %>
    </div>

    <div>
      <%= f.label :billing_cycle, class: "block text-gray-700 font-medium mb-1" %>
      <%= f.select :billing_cycle, options_for_select(Day085::Subscription.billing_cycles.map { |k, v| [k.humanize, k] }, subscription.billing_cycle), {}, class: "w-full border rounded px-3 py-2" %>
    </div>

    <div>
      <%= f.label :status, class: "block text-gray-700 font-medium mb-1" %>
      <%= f.select :status, options_for_select(Day085::Subscription.statuses.map { |k, v| [k.humanize, k] }, subscription.status), {}, class: "w-full border rounded px-3 py-2" %>
    </div>

    <div>
      <%= f.label :start_date, class: "block text-gray-700 font-medium mb-1" %>
      <%= f.date_field :start_date, class: "w-full border rounded px-3 py-2" %>
    </div>

    <div>
      <%= f.label :end_date, class: "block text-gray-700 font-medium mb-1" %>
      <%= f.date_field :end_date, class: "w-full border rounded px-3 py-2" %>
    </div>

    <div>
      <%= f.label :website, class: "block text-gray-700 font-medium mb-1" %>
      <%= f.url_field :website, placeholder: "https://example.com", class: "w-full border rounded px-3 py-2" %>
    </div>
  </div>

  <div class="mt-4">
    <%= f.label :description, class: "block text-gray-700 font-medium mb-1" %>
    <%= f.text_area :description, rows: 3, class: "w-full border rounded px-3 py-2" %>
  </div>

  <div class="mt-6 flex gap-4">
    <%= f.submit (subscription.new_record? ? "Create" : "Update"), class: "bg-blue-500 text-white px-6 py-2 rounded hover:bg-blue-600" %>
    <%= link_to "Cancel", day085_subscriptions_path, class: "bg-gray-500 text-white px-6 py-2 rounded hover:bg-gray-600" %>
  </div>
<% end %>
