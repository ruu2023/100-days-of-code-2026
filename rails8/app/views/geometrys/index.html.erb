<!DOCTYPE html>
<html>
<head>
  <title>Geometry Shapes</title>
  <style>
    body {
      font-family: system-ui, sans-serif;
      max-width: 800px;
      margin: 40px auto;
      padding: 20px;
      background: #f5f5f5;
    }
    h1 {
      text-align: center;
      color: #333;
    }
    .shapes-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      margin-top: 30px;
    }
    .shape-card {
      background: white;
      border-radius: 12px;
      padding: 20px;
      text-align: center;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      transition: transform 0.2s;
    }
    .shape-card:hover {
      transform: translateY(-4px);
    }
    .shape-card img, .shape-card svg {
      max-width: 150px;
      height: 150px;
    }
    .shape-card h3 {
      margin: 15px 0 5px;
      color: #555;
    }
    .shape-card a {
      display: inline-block;
      margin-top: 10px;
      padding: 8px 16px;
      background: #3498db;
      color: white;
      text-decoration: none;
      border-radius: 6px;
      font-size: 14px;
    }
    .shape-card a:hover {
      background: #2980b9;
    }
  </style>
</head>
<body>
  <h1>Geometry Shapes</h1>
  <div class="shapes-grid">
    <% @shapes.each do |shape| %>
      <div class="shape-card">
        <img src="<%= geometrys_shape_path(shape) %>" alt="<%= shape %>">
        <h3><%= shape.capitalize %></h3>
        <a href="<%= geometrys_shape_path(shape) %>">View SVG</a>
      </div>
    <% end %>
  </div>
</body>
</html>
