<div class="min-h-screen bg-gradient-to-br from-slate-900 to-slate-800 text-white p-8">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold mb-2 flex items-center justify-center gap-3">
        <svg class="w-10 h-10 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/>
          <circle cx="12" cy="12" r="6" opacity="0.6"/>
          <circle cx="12" cy="12" r="2" opacity="0.3"/>
        </svg>
        重なり図形の面積計算
      </h1>
      <p class="text-slate-400">Rubyで幾何学図形の面積を計算しよう</p>
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- SVG表示 -->
      <div class="bg-slate-800/50 backdrop-blur rounded-2xl p-6 border border-slate-700">
        <h2 class="text-xl font-semibold mb-4 flex items-center gap-2 text-emerald-400">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <circle cx="12" cy="12" r="4"/>
          </svg>
          SVG表示
        </h2>
        <div class="flex justify-center bg-slate-900/50 rounded-xl p-6">
          <div class="bg-white rounded-lg p-4">
            <svg width="300" height="300" viewBox="0 0 300 300" xmlns="http://www.w3.org/2000/svg">
              <circle cx="120" cy="120" r="80" fill="#3498db" opacity="0.6" stroke="#2c3e50" stroke-width="2"/>
              <circle cx="180" cy="120" r="60" fill="#e74c3c" opacity="0.6" stroke="#2c3e50" stroke-width="2"/>
              <rect x="100" y="80" width="120" height="100" fill="#2ecc71" opacity="0.6" stroke="#2c3e50" stroke-width="2"/>
            </svg>
          </div>
        </div>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="px-3 py-1 bg-blue-500/20 text-blue-400 rounded-full text-sm">円 (半径80)</span>
          <span class="px-3 py-1 bg-red-500/20 text-red-400 rounded-full text-sm">円 (半径60)</span>
          <span class="px-3 py-1 bg-emerald-500/20 text-emerald-400 rounded-full text-sm">長方形 (120×100)</span>
        </div>
      </div>

      <!-- Rubyコード -->
      <div class="bg-slate-800/50 backdrop-blur rounded-2xl p-6 border border-slate-700">
        <h2 class="text-xl font-semibold mb-4 flex items-center gap-2 text-yellow-400">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="16,18 22,12 16,6"/>
            <polyline points="8,6 2,12 8,18"/>
          </svg>
          Rubyコード
        </h2>
        <div class="bg-slate-900 rounded-xl p-4 overflow-x-auto">
          <pre class="text-sm leading-relaxed"><code><%= @highlighted_code.html_safe %></code></pre>
        </div>
        <p class="mt-4 text-slate-400 text-sm">
          このコードはRubyインタプリタで実行可能です
        </p>
      </div>

      <!-- 計算結果 -->
      <div class="bg-slate-800/50 backdrop-blur rounded-2xl p-6 border border-slate-700">
        <h2 class="text-xl font-semibold mb-4 flex items-center gap-2 text-purple-400">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="4" y="4" width="16" height="16" rx="2"/>
            <line x1="8" y1="12" x2="16" y2="12"/>
            <line x1="12" y1="8" x2="12" y2="16"/>
          </svg>
          計算結果
        </h2>
        <div class="space-y-4">
          <% @area_results[:individual].each do |result| %>
            <div class="bg-slate-900/50 rounded-lg p-4">
              <div class="flex justify-between items-center">
                <span class="font-medium text-slate-300"><%= result[:name] %></span>
                <span class="text-2xl font-bold text-white"><%= result[:area].round(2) %></span>
              </div>
              <div class="text-sm text-slate-500 mt-1">
                公式: <%= result[:formula] %>
              </div>
            </div>
          <% end %>
          <div class="bg-gradient-to-r from-purple-500/20 to-pink-500/20 rounded-lg p-4 border border-purple-500/30">
            <div class="flex justify-between items-center">
              <span class="font-bold text-purple-300">合計面積</span>
              <span class="text-3xl font-bold text-white"><%= @area_results[:total].round(2) %></span>
            </div>
          </div>
        </div>
      </div>

      <!-- 面積内訳 -->
      <div class="bg-slate-800/50 backdrop-blur rounded-2xl p-6 border border-slate-700">
        <h2 class="text-xl font-semibold mb-4 flex items-center gap-2 text-cyan-400">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14,2 14,8 20,8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
          </svg>
          面積内訳
        </h2>
        <div class="space-y-3">
          <div class="flex items-center gap-3 p-3 bg-blue-500/10 rounded-lg border border-blue-500/20">
            <div class="w-4 h-4 rounded-full bg-blue-500"></div>
            <div class="flex-1">
              <div class="font-medium">円 1</div>
              <div class="text-sm text-slate-400">半径 80</div>
            </div>
            <div class="text-right">
              <div class="font-mono text-blue-400">π × 80²</div>
              <div class="text-sm text-slate-400">= <%= (Math::PI * 80 ** 2).round(2) %></div>
            </div>
          </div>
          <div class="flex items-center gap-3 p-3 bg-red-500/10 rounded-lg border border-red-500/20">
            <div class="w-4 h-4 rounded-full bg-red-500"></div>
            <div class="flex-1">
              <div class="font-medium">円 2</div>
              <div class="text-sm text-slate-400">半径 60</div>
            </div>
            <div class="text-right">
              <div class="font-mono text-red-400">π × 60²</div>
              <div class="text-sm text-slate-400">= <%= (Math::PI * 60 ** 2).round(2) %></div>
            </div>
          </div>
          <div class="flex items-center gap-3 p-3 bg-emerald-500/10 rounded-lg border border-emerald-500/20">
            <div class="w-4 h-4 rounded bg-emerald-500"></div>
            <div class="flex-1">
              <div class="font-medium">長方形</div>
              <div class="text-sm text-slate-400">120 × 100</div>
            </div>
            <div class="text-right">
              <div class="font-mono text-emerald-400">120 × 100</div>
              <div class="text-sm text-slate-400">= 12000</div>
            </div>
          </div>
        </div>
        <div class="mt-4 p-4 bg-slate-900/50 rounded-lg">
          <div class="text-sm text-slate-400 mb-2">※ 重なり部分の面積は別途計算が必要です</div>
          <div class="text-xs text-slate-500">
            union-find や蒙特卡罗法などで重なり領域を計算できます
          </div>
        </div>
      </div>
    </div>

    <!-- Navigation -->
    <div class="mt-12 text-center">
      <a href="/geometrys" class="inline-flex items-center gap-2 px-6 py-3 bg-slate-700 hover:bg-slate-600 rounded-xl transition-colors">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="19" y1="12" x2="5" y2="12"/>
          <polyline points="12,19 5,12 12,5"/>
        </svg>
        他の図形を見る
      </a>
    </div>
  </div>
</div>
