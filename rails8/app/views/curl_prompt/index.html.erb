<div class="max-w-5xl mx-auto p-6">
  <div class="flex flex-col md:flex-row items-center justify-between mb-8 gap-4">
    <div>
      <h1 class="text-3xl font-bold text-slate-800 tracking-tight">Curl Prompt Maker</h1>
      <p class="text-slate-500 mt-1">Easily generate properly escaped curl commands for your API requests.</p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <!-- Left form -->
    <div class="bg-white p-6 rounded-2xl border shadow-sm h-fit">
      <form id="curlForm" class="space-y-5" data-turbo="false">
        <div class="flex gap-4">
          <div class="w-1/3">
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">Method</label>
            <select name="askmethod" id="askmethod"
                    class="w-full px-3 py-2.5 border border-slate-300 rounded-lg bg-slate-50 focus:bg-white focus:ring-2 focus:ring-slate-800 focus:border-slate-800 outline-none transition-all cursor-pointer">
              <option value="GET">GET</option>
              <option value="POST" selected>POST</option>
              <option value="PUT">PUT</option>
              <option value="DELETE">DELETE</option>
              <option value="PATCH">PATCH</option>
            </select>
          </div>
          <div class="w-2/3">
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">URL <span class="text-red-500">*</span></label>
            <input type="url" name="askurl" id="askurl" required
                   class="w-full px-3 py-2.5 border border-slate-300 rounded-lg focus:ring-2 focus:ring-slate-800 focus:border-slate-800 outline-none transition-all font-mono text-sm"
                   placeholder="https://api.example.com/v1/users">
          </div>
        </div>

        <div>
          <label class="block text-sm font-semibold text-slate-700 mb-1.5">
            Custom Headers
            <span class="text-xs font-normal text-slate-400 ml-1">(One per line)</span>
          </label>
          <textarea name="askheaders" id="askheaders" rows="2"
                    class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm bg-slate-50 focus:bg-white focus:ring-2 focus:ring-slate-800 focus:border-slate-800 outline-none transition-all font-mono"
                    placeholder="Authorization: Bearer my-token&#10;X-Custom-Auth: value"></textarea>
        </div>

        <div>
          <label class="block text-sm font-semibold text-slate-700 mb-1.5">Content-Type</label>
          <select name="askcontent" id="askcontent"
                  class="w-full px-3 py-2.5 border border-slate-300 rounded-lg bg-slate-50 focus:bg-white focus:ring-2 focus:ring-slate-800 focus:border-slate-800 outline-none transition-all cursor-pointer">
            <option value="">(None)</option>
            <option value="application/json" selected>application/json</option>
            <option value="application/x-www-form-urlencoded">application/x-www-form-urlencoded</option>
            <option value="multipart/form-data">multipart/form-data</option>
            <option value="application/xml">application/xml</option>
            <option value="text/plain">text/plain</option>
          </select>
        </div>

        <div id="bodySection">
          <label class="block text-sm font-semibold text-slate-700 mb-1.5">
            Request Body
          </label>
          <textarea name="askbody" id="askbody" rows="6"
                    class="w-full px-4 py-3 border border-slate-300 rounded-lg font-mono text-sm bg-slate-900 text-emerald-400 focus:ring-2 focus:ring-slate-800 focus:border-slate-800 outline-none transition-all shadow-inner placeholder:text-slate-600"
                    placeholder='{
  "name": "John Doe",
  "email": "john@example.com"
}'></textarea>
        </div>

        <div class="flex items-center gap-2 py-2 px-1">
          <input type="checkbox" id="mockMode" class="w-4 h-4 text-emerald-600 border-slate-300 rounded focus:ring-emerald-500">
          <label for="mockMode" class="text-sm font-medium text-slate-600 cursor-pointer">Mock Mode (Test with trivia response)</label>
        </div>

        <button type="submit" id="sendRequestBtn"
                class="w-full py-3 bg-black font-medium text-white rounded-lg hover:bg-slate-800 focus:ring-4 focus:ring-slate-200 transition-all flex items-center justify-center gap-2 shadow-md">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
          Send Request
        </button>
      </form>
    </div>

    <!-- Right Result -->
    <div class="bg-[#1e1e1e] rounded-2xl border border-slate-800 shadow-xl p-6 flex flex-col relative text-slate-300 min-h-[400px]">
      <div class="flex items-center justify-between mb-4 border-b border-slate-700 pb-4">
        <div class="flex items-center gap-2">
          <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
          <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
          <span class="ml-2 text-xs font-semibold text-slate-400 font-mono tracking-wider">TERMINAL</span>
        </div>
        
        <button onclick="copyToClipboard()" id="copyBtn"
                class="hidden px-3 py-1.5 bg-white/10 hover:bg-white/20 rounded-md text-xs font-medium text-white transition-all flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
          Copy Code
        </button>
      </div>

      <div id="placeholder" class="flex-1 flex flex-col items-center justify-center text-slate-500 text-sm">
        <svg class="w-12 h-12 mb-3 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 9l3 3-3 3m5 0h3M4 6h16a2 2 0 012 2v10a2 2 0 01-2 2H4a2 2 0 01-2-2V8a2 2 0 012-2z"></path></svg>
        <p>Type URL to generate curl command</p>
      </div>

      <div id="commandContainer" class="hidden flex-1 flex flex-col h-full overflow-hidden">
        <!-- Curl Output -->
        <pre id="curlOutput" class="font-mono text-sm text-emerald-400 overflow-x-auto whitespace-pre-wrap break-all leading-relaxed mb-4 pb-2"></pre>

        <!-- Response Container -->
        <div id="responseContainer" class="hidden mt-auto pt-4 border-t border-slate-700 flex-1 flex flex-col min-h-[50%]">
          <div class="flex items-center justify-between mb-3 shrink-0">
            <span class="text-xs font-semibold text-slate-400 font-mono tracking-wider">RESPONSE</span>
            <div class="flex items-center gap-2">
              <span id="responseTime" class="text-xs text-slate-500 font-mono"></span>
              <span id="responseStatus" class="px-2 py-0.5 rounded text-xs font-bold font-mono"></span>
            </div>
          </div>
          <div class="flex-1 overflow-y-auto bg-black/30 p-4 rounded-lg border border-slate-700/50">
            <pre id="responseBody" class="font-mono text-sm text-slate-300 whitespace-pre-wrap break-all leading-relaxed"></pre>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script nonce="<%= content_security_policy_nonce %>">
// Escape string for bash literal (wrap in single quotes)
function bashEscape(str) {
  if (!str) return "''";
  return "'" + str.replace(/'/g, "'\\''") + "'";
}

// Live Preview logic
function generateCurl() {
  const method = document.getElementById('askmethod').value || 'GET';
  const url = document.getElementById('askurl').value.trim();
  const headersStr = document.getElementById('askheaders').value;
  const contentStr = document.getElementById('askcontent').value;
  const body = document.getElementById('askbody').value;

  if (!url) return '';

  let lines = [`curl -X ${bashEscape(method)} ${bashEscape(url)}`];

  if (contentStr) {
    lines.push(`-H ${bashEscape("Content-Type: " + contentStr)}`);
  }

  if (headersStr) {
    const customHeaders = headersStr.split('\n');
    for (let h of customHeaders) {
      h = h.trim();
      if (h) lines.push(`-H ${bashEscape(h)}`);
    }
  }

  if (body && method !== 'GET' && method !== 'DELETE') {
    lines.push(`-d ${bashEscape(body)}`);
  }

  return lines.join(" \\\n  ");
}

function updatePreview() {
  const url = document.getElementById('askurl').value.trim();
  const placeholder = document.getElementById('placeholder');
  const commandContainer = document.getElementById('commandContainer');
  const curlOutput = document.getElementById('curlOutput');
  const copyBtn = document.getElementById('copyBtn');

  if (!url) {
    placeholder.classList.remove('hidden');
    commandContainer.classList.add('hidden');
    copyBtn.classList.add('hidden');
    return;
  }

  placeholder.classList.add('hidden');
  commandContainer.classList.remove('hidden');
  copyBtn.classList.remove('hidden');
  
  curlOutput.textContent = generateCurl();
}

// Attach listeners
['askmethod', 'askurl', 'askheaders', 'askcontent', 'askbody'].forEach(id => {
  document.getElementById(id).addEventListener('input', updatePreview);
  document.getElementById(id).addEventListener('change', updatePreview);
});

// Toggle body field visibility
const methodSelect = document.getElementById('askmethod');
const bodySection = document.getElementById('bodySection');
function updateBodyVisibility() {
  if (methodSelect.value === 'GET' || methodSelect.value === 'DELETE') {
    bodySection.style.display = 'none';
  } else {
    bodySection.style.display = 'block';
  }
}
methodSelect.addEventListener('change', updateBodyVisibility);
updateBodyVisibility();
updatePreview();

// Form Submit -> Send Request
document.getElementById('curlForm').addEventListener('submit', async (e) => {
  e.preventDefault();

  const btn = document.getElementById('sendRequestBtn');
  const originalBtnHtml = btn.innerHTML;
  btn.innerHTML = `<svg class="animate-spin h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Sending...`;
  btn.disabled = true;

  const responseContainer = document.getElementById('responseContainer');
  const responseStatus = document.getElementById('responseStatus');
  const responseTime = document.getElementById('responseTime');
  const responseBody = document.getElementById('responseBody');
  
  responseContainer.classList.remove('hidden');
  responseStatus.textContent = 'Loading...';
  responseStatus.className = 'px-2 py-0.5 rounded text-xs font-bold font-mono bg-slate-700 text-slate-300 border border-slate-600';
  responseTime.textContent = '';
  responseBody.textContent = 'Waiting for response...';

  const formData = new FormData(e.target);
  const params = new URLSearchParams();
  for (const [key, value] of formData.entries()) {
    if (value) params.append(key, value);
  }

  try {
    const isMock = document.getElementById('mockMode').checked;
    const fetchUrl = isMock ? '/curl_prompt/mock' : '/curl_prompt/send_request';

    const response = await fetch(fetchUrl, {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: params
    });

    const data = await response.json();

    if (data.error) {
      responseStatus.textContent = 'Error';
      responseStatus.className = 'px-2 py-0.5 rounded text-xs font-bold font-mono bg-red-900/50 text-red-200 border border-red-800';
      responseBody.textContent = data.error;
      return;
    }

    // Status styling
    responseStatus.textContent = `${data.status} ${data.status_message}`;
    if (data.status >= 200 && data.status < 300) {
      responseStatus.className = 'px-2 py-0.5 rounded text-xs font-bold font-mono bg-emerald-900/50 text-emerald-400 border border-emerald-800';
    } else if (data.status >= 400 && data.status < 500) {
      responseStatus.className = 'px-2 py-0.5 rounded text-xs font-bold font-mono bg-yellow-900/50 text-yellow-400 border border-yellow-800';
    } else {
      responseStatus.className = 'px-2 py-0.5 rounded text-xs font-bold font-mono bg-red-900/50 text-red-400 border border-red-800';
    }

    responseTime.textContent = `${data.duration_ms}ms`;

    // Format body
    if (typeof data.body === 'object' && data.body !== null) {
      responseBody.textContent = JSON.stringify(data.body, null, 2);
    } else {
      responseBody.textContent = data.raw_body || '(empty response)';
    }
  } catch (err) {
    responseStatus.textContent = 'Network Error';
    responseStatus.className = 'px-2 py-0.5 rounded text-xs font-bold font-mono bg-red-900/50 text-red-200 border border-red-800';
    responseBody.textContent = err.toString();
  } finally {
    btn.innerHTML = originalBtnHtml;
    btn.disabled = false;
  }
});

function copyToClipboard() {
  const text = document.getElementById('curlOutput').textContent;
  if (!text) return;
  navigator.clipboard.writeText(text);
  
  const btn = document.getElementById('copyBtn');
  const originalHtml = btn.innerHTML;
  btn.innerHTML = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Copied!`;
  btn.classList.add('text-emerald-400');
  
  setTimeout(() => {
    btn.innerHTML = originalHtml;
    btn.classList.remove('text-emerald-400');
  }, 2000);
}

// Shortcut
document.getElementById('curlForm').addEventListener('keydown', function(e) {
  if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
    e.preventDefault();
    this.dispatchEvent(new Event('submit'));
  }
});
</script>
