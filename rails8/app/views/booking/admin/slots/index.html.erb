<div class="mx-auto flex w-full max-w-7xl flex-col gap-8 px-4 py-8">
  <header class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-sky-700">Booking Admin</p>
      <h1 class="text-3xl font-semibold text-slate-900"><%= @owner.name %> Slots</h1>
      <p class="text-sm text-slate-500">Public URL: <%= booking_owner_url(@owner.slug) %></p>
    </div>
    <%= link_to "Back to owners", booking_admin_owners_path, class: "rounded-full border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700" %>
  </header>

  <div class="grid gap-8 xl:grid-cols-[minmax(0,360px)_1fr]">
    <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-slate-900">New slot</h2>
      <%= form_with model: @slot, url: booking_admin_owner_slots_path(@owner), class: "mt-5 space-y-4" do |form| %>
        <div>
          <%= form.label :label, class: "mb-1 block text-sm font-medium text-slate-700" %>
          <%= form.text_field :label, class: "w-full rounded-2xl border border-slate-300 px-4 py-3", placeholder: "初回相談枠" %>
        </div>
        <div>
          <%= form.label :starts_at, class: "mb-1 block text-sm font-medium text-slate-700" %>
          <%= form.datetime_local_field :starts_at, class: "w-full rounded-2xl border border-slate-300 px-4 py-3" %>
        </div>
        <div>
          <%= form.label :ends_at, class: "mb-1 block text-sm font-medium text-slate-700" %>
          <%= form.datetime_local_field :ends_at, class: "w-full rounded-2xl border border-slate-300 px-4 py-3" %>
        </div>
        <div>
          <%= form.label :capacity, class: "mb-1 block text-sm font-medium text-slate-700" %>
          <%= form.number_field :capacity, min: 1, class: "w-full rounded-2xl border border-slate-300 px-4 py-3" %>
        </div>
        <div class="flex items-center gap-3">
          <%= form.check_box :active, class: "h-4 w-4 rounded border-slate-300" %>
          <%= form.label :active, class: "text-sm font-medium text-slate-700" %>
        </div>
        <%= form.submit "Create slot", class: "w-full rounded-2xl bg-sky-600 px-4 py-3 font-semibold text-white" %>
      <% end %>
    </section>

    <section class="rounded-3xl border border-slate-200 bg-slate-50 p-6">
      <h2 class="text-lg font-semibold text-slate-900">Registered slots</h2>
      <div class="mt-5 grid gap-4">
        <% @slots.each do |slot| %>
          <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
            <div class="flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
              <div>
                <h3 class="text-lg font-semibold text-slate-900"><%= slot.display_label %></h3>
                <p class="text-sm text-slate-500"><%= l slot.starts_at, format: :long %> - <%= slot.ends_at.strftime("%H:%M") %></p>
              </div>
              <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold <%= slot.available? ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-200 text-slate-700' %>">
                <%= slot.available? ? "Available" : "Unavailable" %>
              </span>
            </div>
          </article>
        <% end %>
      </div>
    </section>
  </div>
</div>
