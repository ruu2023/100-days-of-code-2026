<div class="min-h-screen bg-[radial-gradient(circle_at_top_left,_rgba(251,191,36,0.18),_transparent_28%),linear-gradient(180deg,_#fffdf7_0%,_#f8fafc_40%,_#eef2ff_100%)] px-4 py-8 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="mb-8 flex flex-wrap items-end justify-between gap-4">
      <div>
        <p class="mb-2 text-xs font-semibold uppercase tracking-[0.4em] text-amber-600">Rails 8 Demo</p>
        <h1 class="text-4xl font-black tracking-tight text-slate-900">Excel感覚のマスタ管理画面</h1>
        <p class="mt-3 max-w-3xl text-sm leading-6 text-slate-600">
          一覧・検索・CRUD は先に完成させ、頻度の高い在庫・単価・状態だけを Turbo Frames で行内編集できる構成にしています。
        </p>
      </div>
      <div class="flex gap-3">
        <%= link_to "ActiveAdmin", admin_master_products_path, class: "rounded-full border border-slate-300 bg-white px-5 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:border-slate-400" %>
        <%= link_to "新規ページへ", new_master_demo_product_path, class: "rounded-full bg-amber-400 px-5 py-2 text-sm font-semibold text-slate-900 hover:bg-amber-300" %>
      </div>
    </div>

    <% if notice.present? %>
      <div class="mb-6 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700"><%= notice %></div>
    <% end %>

    <div class="mb-6 rounded-3xl border border-white/80 bg-white/85 p-5 shadow-[0_18px_40px_rgba(15,23,42,0.08)] backdrop-blur">
      <%= form_with url: master_demo_products_path, method: :get, data: { turbo_frame: "master_products_sheet" }, class: "grid gap-3 md:grid-cols-4 xl:grid-cols-[2fr,1fr,1fr,auto]" do |f| %>
        <%= f.search_field :q, value: params[:q], placeholder: "商品名またはSKUで検索", class: "rounded-xl border border-slate-300 px-3 py-2 text-sm" %>
        <%= f.select :category, options_for_select(MasterProduct.category_options, params[:category]), { include_blank: "すべてのカテゴリ" }, class: "rounded-xl border border-slate-300 px-3 py-2 text-sm" %>
        <%= f.select :status, options_for_select(MasterProduct::STATUSES, params[:status]), { include_blank: "すべての状態" }, class: "rounded-xl border border-slate-300 px-3 py-2 text-sm" %>
        <div class="flex gap-2">
          <%= f.submit "検索", class: "w-full rounded-full bg-slate-900 px-5 py-2 text-sm font-semibold text-white hover:bg-slate-700" %>
          <%= link_to "クリア", master_demo_products_path, class: "rounded-full border border-slate-300 bg-white px-5 py-2 text-sm font-semibold text-slate-600 hover:border-slate-400" %>
        </div>
      <% end %>
    </div>

    <div class="mb-6 rounded-3xl border border-slate-200 bg-white/90 p-5 shadow-[0_18px_40px_rgba(15,23,42,0.08)]">
      <div class="mb-4 flex items-center justify-between">
        <div>
          <p class="text-xs uppercase tracking-[0.3em] text-slate-400">Quick Add</p>
          <h2 class="text-lg font-semibold text-slate-900">新しい行を追加</h2>
        </div>
        <p class="text-xs text-slate-500">詳細な項目編集は通常の編集ページで対応します。</p>
      </div>
      <%= render "form", master_product: @master_product %>
    </div>

    <%= render "table", master_products: @master_products %>
  </div>
</div>
