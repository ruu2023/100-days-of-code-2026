<div class="mx-auto max-w-3xl px-4 py-8 sm:px-6 lg:px-8">
  <div class="mb-6">
    <p class="text-xs uppercase tracking-[0.3em] text-amber-600">Master Demo</p>
    <h1 class="text-3xl font-bold text-slate-900">商品マスタを新規作成</h1>
  </div>

  <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
    <%= form_with model: @master_product, url: master_demo_products_path, class: "space-y-5" do |f| %>
      <% if @master_product.errors.any? %>
        <div class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
          <%= @master_product.errors.full_messages.to_sentence %>
        </div>
      <% end %>

      <div class="grid gap-4 md:grid-cols-2">
        <%= f.text_field :sku, placeholder: "SKU", class: "rounded-xl border border-slate-300 px-3 py-2 text-sm" %>
        <%= f.text_field :name, placeholder: "商品名", class: "rounded-xl border border-slate-300 px-3 py-2 text-sm" %>
        <%= f.text_field :category, placeholder: "カテゴリ", class: "rounded-xl border border-slate-300 px-3 py-2 text-sm" %>
        <%= f.text_field :supplier, placeholder: "仕入先", class: "rounded-xl border border-slate-300 px-3 py-2 text-sm" %>
        <%= f.number_field :stock, min: 0, class: "rounded-xl border border-slate-300 px-3 py-2 text-sm" %>
        <%= f.text_field :unit, class: "rounded-xl border border-slate-300 px-3 py-2 text-sm" %>
        <%= f.number_field :price, min: 0, step: 1, class: "rounded-xl border border-slate-300 px-3 py-2 text-sm" %>
        <%= f.number_field :position, min: 0, class: "rounded-xl border border-slate-300 px-3 py-2 text-sm" %>
        <%= f.select :status, options_for_select(MasterProduct::STATUSES, @master_product.status), {}, class: "rounded-xl border border-slate-300 px-3 py-2 text-sm md:col-span-2" %>
      </div>
      <%= f.text_area :notes, rows: 4, placeholder: "備考", class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-sm" %>

      <div class="flex items-center justify-between">
        <%= link_to "一覧へ戻る", master_demo_products_path, class: "text-sm font-medium text-slate-500 hover:text-slate-700" %>
        <%= f.submit "登録する", class: "rounded-full bg-slate-900 px-5 py-2 text-sm font-semibold text-white hover:bg-slate-700" %>
      </div>
    <% end %>
  </div>
</div>
