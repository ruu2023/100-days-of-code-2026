<div class="max-w-4xl mx-auto p-6">
  <h1 class="text-2xl font-bold mb-6">CSV → Markdown / Excel Table</h1>

  <%= form_with url: csv_tables_path, method: :get, local: true do |f| %>
    <div class="mb-4">
      <%= f.label :csv_text, "CSVテキスト（1行目がヘッダー）", class: "block mb-2 font-medium" %>
      <%= f.text_area :csv_text, value: @csv_text, rows: 8, class: "w-full border p-2 font-mono text-sm", placeholder: "name,age,city\nAlice,30,Tokyo\nBob,25,Osaka" %>
    </div>
    <%= f.submit "変換", class: "bg-blue-500 text-white px-4 py-2 rounded cursor-pointer" %>
  <% end %>

  <% if @parsed_rows %>
    <div class="mt-8 grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Markdown Table -->
      <div>
        <h2 class="text-lg font-semibold mb-3">Markdown 表</h2>
        <div class="bg-gray-100 p-4 rounded overflow-auto max-h-96">
          <table class="border-collapse border border-gray-400 text-sm">
            <thead>
              <tr>
                <% @parsed_rows[:headers].each do |header| %>
                  <th class="border border-gray-400 px-3 py-1 bg-gray-200 font-semibold"><%= header %></th>
                <% end %>
              </tr>
            </thead>
            <tbody>
              <% @parsed_rows[:rows].each do |row| %>
                <tr>
                  <% row.each do |cell| %>
                    <td class="border border-gray-400 px-3 py-1"><%= cell %></td>
                  <% end %>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        <details class="mt-2">
          <summary class="cursor-pointer text-blue-600 hover:underline">Markdownソースを表示</summary>
          <pre class="mt-2 p-2 bg-gray-800 text-green-400 rounded text-xs overflow-auto max-h-48"><%= generate_markdown(@parsed_rows) %></pre>
        </details>
      </div>

      <!-- Excel-copyable Table -->
      <div>
        <h2 class="text-lg font-semibold mb-3">Excel用（コピーして貼り付け）</h2>
        <p class="text-sm text-gray-600 mb-2">下の表をCtrl+C / Cmd+CでコピーしてExcelに貼り付けできます</p>
        <div class="bg-white border-2 border-blue-400 p-4 rounded overflow-auto max-h-96" id="excel-table">
          <table class="border-collapse">
            <thead>
              <tr>
                <% @parsed_rows[:headers].each do |header| %>
                  <th class="border border-gray-500 px-3 py-1 bg-gray-100 font-semibold text-left"><%= header %></th>
                <% end %>
              </tr>
            </thead>
            <tbody>
              <% @parsed_rows[:rows].each do |row| %>
                <tr>
                  <% row.each do |cell| %>
                    <td class="border border-gray-400 px-3 py-1"><%= cell %></td>
                  <% end %>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        <button onclick="copyTable()" class="mt-2 bg-green-500 text-white px-4 py-2 rounded cursor-pointer text-sm">クリップボードにコピー</button>
        <span id="copy-status" class="ml-2 text-green-600 text-sm hidden">コピーしました！</span>
      </div>
    </div>
  <% elsif @csv_text.present? %>
    <p class="mt-4 text-red-600">CSVの解析に失敗しました。形式を確認してください。</p>
  <% end %>
</div>

<script>
function copyTable() {
  const table = document.querySelector('#excel-table table');
  const range = document.createRange();
  range.selectNode(table);
  window.getSelection().removeAllRanges();
  window.getSelection().addRange(range);
  document.execCommand('copy');
  window.getSelection().removeAllRanges();
  const status = document.getElementById('copy-status');
  status.classList.remove('hidden');
  setTimeout(() => status.classList.add('hidden'), 2000);
}
</script>
