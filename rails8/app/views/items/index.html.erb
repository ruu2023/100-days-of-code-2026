<div class="max-w-md mx-auto p-4">

  <div class="mb-4">
    <%= link_to "＋ 新規登録", new_item_path, class: "inline-block px-4 py-2 bg-black text-white rounded-xl" %>
  </div>

  <!-- 🔍 検索 -->
  <div class="mb-4">
    <%= form_with url: items_path, method: :get,
      data: { 
        turbo_frame: "items",
        controller: "autosubmit"
      } do %>
      <%= text_field_tag :q, params[:q],
        placeholder: "検索（例：コーヒー）",
        class: "w-full p-3 border rounded-xl",
        data: {
          action: "input->autosubmit#submit"
        } %>
    <% end %>
  </div>

  <!-- 📦 一覧 -->
  <%= turbo_frame_tag "items" do %>
    <%= render "list", items: @items %>
  <% end %>
</div>