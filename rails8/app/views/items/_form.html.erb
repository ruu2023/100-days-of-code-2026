<div class="max-w-md mx-auto p-4">
  <%= form_with model: item, class: "space-y-4" do |f| %>
    <% if item.errors.any? %>
      <div class="rounded-xl bg-red-100 text-red-700 p-3">
        <div class="font-bold mb-2">入力を確認してください</div>
        <ul class="list-disc list-inside text-sm">
          <% item.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, "商品名", class: "block text-sm font-medium mb-1" %>
      <%= f.text_field :name, class: "w-full p-3 border rounded-xl" %>
    </div>

    <div>
      <%= f.label :purchase_cycle_days, "購入周期（日）", class: "block text-sm font-medium mb-1" %>
      <%= f.number_field :purchase_cycle_days, min: 1, class: "w-full p-3 border rounded-xl" %>
    </div>

    <div>
      <%= f.label :last_purchased_on, "前回購入日", class: "block text-sm font-medium mb-1" %>
      <%= f.date_field :last_purchased_on, class: "w-full p-3 border rounded-xl" %>
    </div>

    <div>
      <%= f.label :memo, "メモ", class: "block text-sm font-medium mb-1" %>
      <%= f.text_area :memo, rows: 3, class: "w-full p-3 border rounded-xl" %>
    </div>

    <div class="flex items-center gap-2">
      <%= f.check_box :active %>
      <%= f.label :active, "有効" %>
    </div>

    <div class="flex gap-2">
      <%= f.submit class: "px-4 py-2 bg-black text-white rounded-xl" %>
      <%= link_to "戻る", items_path, class: "px-4 py-2 border rounded-xl" %>
    </div>
  <% end %>
</div>
