{
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(USE_OLLAMA=true node:*)",
      "Bash(grep:*)",
      "WebFetch(domain:github.com)"
    ]
  },
  "autoApprove": {
    "readFiles": true,
    "writeFiles": true,
    "search": true,
    "bash": true
  },
  "maxIterations": 100,
  "retryAttempts": 3
}
